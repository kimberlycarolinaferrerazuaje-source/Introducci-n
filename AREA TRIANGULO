// Realizar un programa que calcule el area de un triangulo, donde se le pida al usuario que ingrese la base y la altura.)
PROCESO AREA TRIANGULO
  ESCRIBIR "PROGRAMA QUE HALLE EL AREA DE UN TRIANGULO"
  ESCRIBIR "."
  ESCRIBIR "."
  ESCRIBIR "DIGITE EL VALOR DE LA BASE"
  LEER BASE
  ESCRIBIR "DIJITE EL VALOR DE LA ALTURA"
  LEER ALTURA
  RESULTADO = (BASE * ALTURA)/2
  ESCRIBIR "."
  ESCRIBIR "SI EL TRIANGULO DE BASE ", BASE, "Y DE ALTURA ", ALTURA, " TIENE UN AREA DE ", RESULTADO
FINPROCESO
