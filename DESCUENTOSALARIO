// CREA UN PROGRAMA QUE CALCULE EL DESCUENTO DE UN 25 % DE UN SALARIO DEVENGADO POR UN EMLEADO, CAPTURA SU NOMBRE Y SU SALARIO.
PROCESO DESCUENTO
  ESCRIBIR "PROGRAMA QUE TE DESCUENTA EL 25 %"
  ESCRIBIR "DIGITE SU NOMBRE"
  LEER NOMBRE
  ESCRIBIR "DIGITE SU SALARIO"
  LEER SALARIO
  PORCENTAJE = SALARIO * 25 / 100 //ESTA LETRTA CALCULA EL PORCENTAJE
  SALARIOTOTAL = SALARIO - PORCENTAJE
    SI SALARIOTOTAL > 1000000 ENTONCES 
      ESCRIBIR "SU SALARIO ES MUY ALTO"
    SINO
      ESCRIBIR "SU SALARIO ES MENOR A UN MILLON,USTED GANA ", SALARIOTOTAL
    FINSI
  

FINPROCESO
